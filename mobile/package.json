{
  "name": "@conek-ai/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Conek AI mobile client — Capacitor remote thin client (iOS + Android). Loads the deployed web UI; no UI fork.",
  "scripts": {
    "sync": "cap sync",
    "sync:ios": "cap sync ios",
    "sync:android": "cap sync android",
    "open:ios": "cap open ios",
    "open:android": "cap open android",
    "resources": "capacitor-assets generate --ios --android --assetPath resources --iconBackgroundColor '#3ABFC6' --iconBackgroundColorDark '#3ABFC6' --splashBackgroundColor '#0B1220' --splashBackgroundColorDark '#0B1220'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"]
  }
}
