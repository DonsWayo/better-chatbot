{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus / VictoriaMetrics datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "description": "asafe-ai production SLO dashboard — TTFT, provider errors, active requests, rate limits, kill switch, compression, routing",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Availability & Kill Switch",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "P50/P95/P99 time-to-first-token. SLO: P95 < 2 s.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(asafe_ai_ttft_ms_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(asafe_ai_ttft_ms_bucket[5m])) by (le))",
          "legendFormat": "P95 (SLO)"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(asafe_ai_ttft_ms_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "title": "Time-to-First-Token (TTFT)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Active in-flight inference requests. Spike here = backpressure risk.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" },
      "targets": [
        {
          "expr": "asafe_ai_active_requests",
          "legendFormat": "Active requests"
        }
      ],
      "title": "Active Requests (gauge)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Kill-switch activation rate. Any value > 0 means the kill switch is active.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "increase(asafe_ai_kill_switch_activations_total[5m])",
          "legendFormat": "Kill-switch activations / 5 min"
        }
      ],
      "title": "Kill Switch Activations",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 10,
      "title": "Provider Errors & Fallbacks",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Provider error rate by provider and error type. SLO: < 1% of requests.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 11,
      "targets": [
        {
          "expr": "sum(rate(asafe_ai_provider_errors_total[5m])) by (provider, error_type)",
          "legendFormat": "{{provider}} / {{error_type}}"
        }
      ],
      "title": "Provider Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Fallback activations — how often we switched to an alternative provider.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 12,
      "targets": [
        {
          "expr": "sum(increase(asafe_ai_provider_fallback_total[1h])) by (primary_provider, fallback_provider)",
          "legendFormat": "{{primary_provider}} → {{fallback_provider}}"
        }
      ],
      "title": "Provider Fallback Activations / hr",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 20,
      "title": "Rate Limiting & Budget",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate-limit rejections by team. High rate = team hitting their quota.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 21,
      "targets": [
        {
          "expr": "sum(increase(asafe_ai_rate_limit_activations_total[5m])) by (team_id)",
          "legendFormat": "Team {{team_id}}"
        }
      ],
      "title": "Rate-Limit Rejections / 5 min",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Chat errors by type (rate_limited, budget_exceeded, unknown).",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 22,
      "targets": [
        {
          "expr": "sum(increase(asafe_chat_errors_total[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ],
      "title": "Chat Errors / 5 min",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 30,
      "title": "Routing & Compression",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Routing decisions by task class and tier — how Auto is distributing load.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 31,
      "targets": [
        {
          "expr": "sum(increase(asafe_routing_decisions_total[5m])) by (task_class, tier)",
          "legendFormat": "{{task_class}} / {{tier}}"
        }
      ],
      "title": "Routing Decisions / 5 min",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Characters saved by context compression. High = compression working effectively.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 32,
      "targets": [
        {
          "expr": "sum(rate(asafe_compression_chars_saved_total[5m])) by (strategy)",
          "legendFormat": "{{strategy}}"
        }
      ],
      "title": "Compression Chars Saved / s",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 40,
      "title": "End-to-End Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Full chat request latency (auth + setup + inference). SLO: P95 < 30 s.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 37 },
      "id": 41,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(asafe_chat_latency_ms_bucket[5m])) by (le, provider))",
          "legendFormat": "P50 {{provider}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(asafe_chat_latency_ms_bucket[5m])) by (le, provider))",
          "legendFormat": "P95 {{provider}}"
        }
      ],
      "title": "Chat End-to-End Latency",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["asafe-ai", "slo", "production"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(asafe_ai_ttft_ms_count, provider)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "provider",
        "options": [],
        "query": {
          "query": "label_values(asafe_ai_ttft_ms_count, provider)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "type": "query",
        "label": "Provider"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "asafe-ai — Production SLOs",
  "uid": "asafe-ai-slo-v1",
  "version": 1
}
